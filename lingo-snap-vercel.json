{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 60 }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/frontend/$1" },
    { "src": "/login", "dest": "/api/index.py" },
    { "src": "/language", "dest": "/api/index.py" },
    { "src": "/contents", "dest": "/api/index.py" },
    { "src": "/seasons", "dest": "/api/index.py" },
    { "src": "/episodes", "dest": "/api/index.py" },
    { "src": "/expressions", "dest": "/api/index.py" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/", "dest": "/api/index.py" }
  ]
}
